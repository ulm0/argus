[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
charset = utf-8
max_line_length = 120

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = space
indent_size = 2

[*.{ts,tsx,js,mjs,jsx}]
indent_style = space
indent_size = 2
max_line_length = 120

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.service]
indent_style = space
indent_size = 2
